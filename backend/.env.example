# Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=5000
NODE_ENV=production

# Comma-separated list of allowed frontend origins.
# Leave unset to allow all origins (use only in dev).
FRONTEND_ORIGIN=http://localhost:3000

# Database (future use)
# DATABASE_URL=postgresql://user:password@localhost:5432/liquidhub

# Security
# JWT_SECRET=your-super-secret-jwt-key-here

# External APIs (future use)
# API_KEY_OPENAI=sk-your-openai-key
# API_KEY_STRIPE=sk_test_your-stripe-key